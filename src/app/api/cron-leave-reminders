async function sendEmail(to, subject, html, replyTo) {
  if (!process.env.RESEND_API_KEY) {
    console.warn("RESEND_API_KEY missing")
    return { ok: false, error: "no_api_key" }
  }
  try {
    var res = await fetch("https://api.resend.com/emails", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": "Bearer " + process.env.RESEND_API_KEY
      },
      body: JSON.stringify({
        from: "Meshuga RH <events@meshuga.fr>",
        to: [to],
        subject: subject,
        html: html,
        reply_to: replyTo || "events@meshuga.fr",
        bcc: ["events@meshuga.fr"]
      })
    })
    if (!res.ok) {
      var err = await res.text()
      return { ok: false, error: err }
    }
    var data = await res.json()
    return { ok: true, id: data.id }
  } catch (err) {
    return { ok: false, error: String(err) }
  }
}

export async function GET(request) {
  // Auth : vérifie le secret cron Vercel
  var authHeader = request.headers.get("authorization")
  if (process.env.CRON_SECRET && authHeader !== "Bearer " + process.env.CRON_SECRET) {
    return NextResponse.json({ error: "unauthorized" }, { status: 401 })
  }

  var today = new Date()
  var trigger = shouldTriggerToday(today)
  if (!trigger) {
    return NextResponse.json({ ok: true, skipped: "no_trigger_today", date: today.toISOString() })
  }

  var refYear = computeReferenceYear(today)

  // Charge tous les salariés ayant un contrat CDI actif (non Extra, non archivé)
  var contractsRes = await supabase
    .from("hr_contracts")
    .select("id, employee_id, type, status, hr_employees(id, prenom, nom, civilite, email)")
    .neq("type", "extra")
    .in("status", ["draft", "finalized", "signed"])

  if (contractsRes.error) {
    return NextResponse.json({ error: contractsRes.error.message }, { status: 500 })
  }

  // Edward (employeur) - on récupère le 1er CDI cadre comme proxy
  var employer = { prenom: "Edward", nom: "TOURET", email: "events@meshuga.fr" }

  var sent = []
  var skipped = []
  var errors = []

  for (var i = 0; i < (contractsRes.data || []).length; i++) {
    var c = contractsRes.data[i]
    var emp = c.hr_employees
    if (!emp || !emp.email) {
      skipped.push({ id: c.id, reason: "no_email" })
      continue
    }

    // Vérifier si on a déjà envoyé un email pour ce trigger cette année
    var existing = await supabase
      .from("hr_leave_requests")
      .select("id, email_sent_at")
      .eq("employee_id", emp.id)
      .eq("reference_year", refYear)
      .eq("notes", "trigger:" + trigger)
      .limit(1)

    if (existing.data && existing.data.length > 0 && existing.data[0].email_sent_at) {
      skipped.push({ id: emp.id, reason: "already_sent_this_trigger" })
      continue
    }

    // Charge le solde si présent
    var balanceRes = await supabase
      .from("hr_leave_balances")
      .select("*")
      .eq("employee_id", emp.id)
      .eq("reference_year", refYear)
      .maybeSingle()
    var balance = balanceRes.data || { days_acquired: 0, days_taken: 0 }
    balance.days_remaining = (balance.days_acquired || 0) - (balance.days_taken || 0)

    // Construit et envoie l'email
    var subjects = {
      march_1: "📅 Tes dates de congés pour mai-octobre",
      april_30: "⏰ Rappel : valide tes congés avant fin avril",
      aug_31: "⚠️ Pense à prendre tes congés restants",
      oct_15: "🚨 URGENT : 15 jours pour tes congés ou un report"
    }
    var html = buildEmailHtml(trigger, employer, emp, balance)
    var emailRes = await sendEmail(emp.email, subjects[trigger], html)

    if (!emailRes.ok) {
      errors.push({ id: emp.id, error: emailRes.error })
      continue
    }

    // Trace en DB
    await supabase.from("hr_leave_requests").insert([{
      employee_id: emp.id,
      contract_id: c.id,
      reference_year: refYear,
      status: "requested",
      email_sent_at: new Date().toISOString(),
      email_sent_to: emp.email,
      notes: "trigger:" + trigger
    }])

    sent.push({ id: emp.id, name: emp.prenom + " " + emp.nom, email: emp.email })
  }

  return NextResponse.json({
    ok: true,
    trigger: trigger,
    reference_year: refYear,
    sent: sent.length,
    skipped: skipped.length,
    errors: errors.length,
    details: { sent: sent, skipped: skipped, errors: errors }
  })
}
