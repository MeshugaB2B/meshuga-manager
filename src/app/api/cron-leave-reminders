// ============================================================
// /api/cron-leave-reminders/route.ts
// ============================================================
// Cron Vercel quotidien (07:00 UTC = 09:00 Paris été) qui :
// 1. Vérifie pour chaque salarié actif si une relance congés est due
// 2. Envoie l'email automatique via Resend
// 3. Crée une notification push pour Edward (employeur)
// 4. Met à jour la table hr_leave_requests
//
// Déclencheurs (4 dates clés / an) :
//   - 1er mars : "Demande à tes salariés de poser leurs congés"
//   - 30 avril : "Plus que 1 mois pour valider les congés"
//   - 31 août : "X jours non pris, à relancer"
//   - 15 octobre : "🚨 Plus que 15 jours pour les prendre / reporter"
// ============================================================

import { createClient } from "@supabase/supabase-js"
import { NextResponse } from "next/server"

export const dynamic = "force-dynamic"
export const runtime = "nodejs"

var supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL || "",
  process.env.SUPABASE_SERVICE_ROLE_KEY || ""
)

// Helper : qui doit être relancé aujourd'hui ?
function shouldTriggerToday(today) {
  var month = today.getMonth() + 1 // 1-12
  var day = today.getDate()
  // Window de tolérance de 3 jours pour ne pas rater à cause d'un cron raté
  if (month === 3 && day >= 1 && day <= 3) return "march_1"
  if (month === 4 && day >= 30) return "april_30"
  if (month === 5 && day === 1) return "april_30"
  if (month === 8 && day >= 31) return "aug_31"
  if (month === 9 && day === 1) return "aug_31"
  if (month === 10 && day >= 15 && day <= 17) return "oct_15"
  return null
}

// Calcul de l'année de référence (1er juin → 31 mai)
function computeReferenceYear(today) {
  var year = today.getFullYear()
  var month = today.getMonth() + 1
  // Du 1er juin année N au 31 mai année N+1 → année de référence = N+1
  if (month >= 6) return year + 1
  return year
}

// Génère le contenu de l'email selon le trigger
